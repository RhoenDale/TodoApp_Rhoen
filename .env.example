# TodoApp Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=todoapp_db
DB_USER=todoapp_user
DB_PASSWORD=your_secure_password_here

# API Configuration
API_PORT=3000
API_BASE_URL=http://localhost:3000/api

# For Production (InfinityFree)
# Update these with your actual InfinityFree domain and database credentials
PRODUCTION_DB_HOST=sql123.infinityfree.com
PRODUCTION_DB_PORT=3306
PRODUCTION_DB_NAME=if0_xxxxx_todoapp
PRODUCTION_DB_USER=if0_xxxxx_user
PRODUCTION_DB_PASSWORD=your_infinityfree_password

PRODUCTION_API_URL=https://yourdomain.infinityfree.com/api

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# App Version
APP_VERSION=1.1.0.0
